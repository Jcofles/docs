{
  "projectType": "saas",
  "projectName": "UniMaps",
  "projectDescription": "A full-stack campus navigation web application for ITFIP university, featuring interactive maps, shortest-path routing, and secure user authentication.",
  "theme": "luma",
  "primaryColor": "#2563EB",
  "lightColor": "#EFF6FF",
  "darkColor": "#1E3A8A",
